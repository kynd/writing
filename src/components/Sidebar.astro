---
type TreeNode = {
  label: string;
  slug: string;
  children: Map<string, TreeNode>;
};

interface Props {
  tree: TreeNode;
  currentSlug: string;
}

const { tree, currentSlug } = Astro.props;

// Recursive HTML string renderer for nested levels
function renderTree(node: TreeNode, depth = 0): string {
  const children = [...node.children.values()];
  if (children.length === 0) return '';

  const indent = (depth + 1) * 14; // px indent per level

  return children.map((child) => {
    const hasChildren = child.children.size > 0;
    const isActive = currentSlug === child.slug || currentSlug.startsWith(child.slug + '/');
    const isCurrentPage = currentSlug === child.slug;
    const activeClass = isActive ? ' active' : '';
    const currentClass = isCurrentPage ? ' current' : '';

    if (hasChildren) {
      const inner = renderTree(child, depth + 1);
      return `
        <li class="si${activeClass}">
          <button class="st${activeClass}" data-slug="${child.slug}" aria-expanded="${isActive}" style="padding-left:${indent}px">
            <span class="sa">${isActive ? '−' : '+'}</span><a href="/${child.slug}" class="sl${currentClass}">${child.label}</a>
          </button>
          <ul class="sc${isActive ? ' open' : ''}">${inner}</ul>
        </li>`;
    } else {
      return `<li class="si${currentClass ? ' cur' : ''}"><a href="/${child.slug}" class="sl${currentClass}" style="padding-left:${indent + 22}px">${child.label}</a></li>`;
    }
  }).join('');
}
---

<ul class="sc open" style="padding-left:0">
  {[...tree.children.values()].map((child) => {
    const hasChildren = child.children.size > 0;
    const isActive = currentSlug === child.slug || currentSlug.startsWith(child.slug + '/');
    const isCurrentPage = currentSlug === child.slug;

    if (hasChildren) {
      return (
        <li class={`si${isActive ? ' active' : ''}`}>
          <button
            class={`st${isActive ? ' active' : ''}`}
            data-slug={child.slug}
            aria-expanded={String(isActive)}
            style="padding-left:14px"
          >
            <span class="sa">{isActive ? '−' : '+'}</span>
            <a href={`/${child.slug}`} class={`sl${isCurrentPage ? ' current' : ''}`}>{child.label}</a>
          </button>
          <ul class={`sc${isActive ? ' open' : ''}`} set:html={renderTree(child, 1)} />
        </li>
      );
    } else {
      return (
        <li class={`si${isCurrentPage ? ' cur' : ''}`}>
          <a href={`/${child.slug}`} class={`sl${isCurrentPage ? ' current' : ''}`} style="padding-left:36px">{child.label}</a>
        </li>
      );
    }
  })}
</ul>

<!-- Global styles so they apply to both JSX-rendered and set:html content -->
<style is:global>
  /* All sidebar lists */
  .sc {
    list-style: none;
    padding: 0;
    margin: 0;
    display: none;
  }
  .sc.open { display: block; }

  .si { margin: 0; }

  /* Shared link style — same for all levels */
  .sl {
    display: block;
    font-family: 'Sora', sans-serif;
    font-size: 0.82rem;
    font-weight: 400;
    line-height: 1.4;
    color: var(--fg-muted);
    text-decoration: none;
    padding: 0.42rem 1.5rem 0.42rem 0;
    white-space: normal;
    transition: background 0.1s;
  }
  .sl:hover { background: #f4f4f4; }
  .sl.current {
    font-weight: 600;
    color: var(--fg);
    background: #f0f0f0;
  }

  /* Toggle button — transparent, flex row */
  .st {
    display: flex;
    align-items: center;
    width: 100%;
    background: none;
    border: none;
    cursor: pointer;
    padding: 0;
    text-align: left;
    font: inherit;
  }
  .st:hover .sl { background: #f4f4f4; }

  /* +/− icon */
  .sa {
    flex-shrink: 0;
    width: 22px;
    font-size: 0.75rem;
    color: #aaa;
    display: inline-flex;
    align-items: center;
    justify-content: center;
    font-family: monospace;
    line-height: 1;
  }
  .st:hover .sa { color: #555; }
  .st.active .sa { color: #555; }

  /* The link inside a toggle takes remaining width */
  .st .sl {
    flex: 1;
    min-width: 0;
    padding-left: 0;
  }
</style>

<script>
  document.querySelectorAll('.st').forEach((btn) => {
    btn.addEventListener('click', (e) => {
      if ((e.target as HTMLElement).tagName === 'A') return;

      const li = btn.closest('.si');
      const children = li?.querySelector(':scope > .sc');
      const icon = btn.querySelector('.sa');
      if (!children || !icon) return;

      const isOpen = children.classList.contains('open');
      children.classList.toggle('open', !isOpen);
      (btn as HTMLButtonElement).setAttribute('aria-expanded', String(!isOpen));
      icon.textContent = isOpen ? '+' : '−';
    });
  });
</script>
