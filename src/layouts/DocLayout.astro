---
import { getCollection } from 'astro:content';
import Sidebar from '../components/Sidebar.astro';

export interface Props {
  title: string;
  slug: string;
}

const { title, slug } = Astro.props;

const allDocs = await getCollection('docs');

type TreeNode = {
  label: string;
  slug: string;
  children: Map<string, TreeNode>;
};

// Desired top-level section order (slug → position)
const SECTION_ORDER: Record<string, number> = {
  'drawing-with-code': 0,
  'sketching-with-math-and-quasi-physics': 1,
  'the-secrets-of-sound-for-kids': 2,
  'category-theory-and-code': 3,
  'on-prototyping-prototyping-is-sketching': 4,
  'faq': 5,
};

function buildTree(docs: typeof allDocs): TreeNode {
  const root: TreeNode = { label: 'root', slug: '', children: new Map() };

  for (const doc of docs) {
    if (doc.slug === 'index') continue; // homepage served at /
    const parts = doc.slug.split('/');
    let node = root;
    for (let i = 0; i < parts.length; i++) {
      const part = parts[i];
      if (!node.children.has(part)) {
        node.children.set(part, {
          label: i === parts.length - 1 ? (doc.data.title || part) : part,
          slug: parts.slice(0, i + 1).join('/'),
          children: new Map(),
        });
      } else if (i === parts.length - 1) {
        const existing = node.children.get(part)!;
        existing.label = doc.data.title || existing.label;
      }
      node = node.children.get(part)!;
    }
  }

  // Sort root-level children by SECTION_ORDER
  const sorted = [...root.children.entries()].sort(([a], [b]) => {
    const oa = SECTION_ORDER[a] ?? 99;
    const ob = SECTION_ORDER[b] ?? 99;
    return oa - ob;
  });
  root.children = new Map(sorted);

  return root;
}

const tree = buildTree(allDocs);

const base = import.meta.env.BASE_URL.replace(/\/$/, '');

function buildBreadcrumbs(slug: string, docs: typeof allDocs) {
  const parts = slug.split('/').filter(Boolean);
  const crumbs: { label: string; href: string }[] = [
    { label: 'Home', href: base || '/' },
  ];

  let cumulative = '';
  for (let i = 0; i < parts.length; i++) {
    cumulative += (i > 0 ? '/' : '') + parts[i];
    const match = docs.find((d) => d.slug === cumulative || d.slug === `${cumulative}/index`);
    crumbs.push({
      label: match?.data.title || parts[i],
      href: `${base}/${cumulative}`,
    });
  }
  return crumbs;
}

const breadcrumbs = buildBreadcrumbs(slug, allDocs);
---

<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>{title}</title>
  <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/katex@0.16.25/dist/katex.min.css" crossorigin="anonymous" />
  <script async src="//www.instagram.com/embed.js"></script>
  <script is:inline>
    (function() {
      var f = localStorage.getItem('font-mode') || 'serif';
      document.documentElement.setAttribute('data-font', f);
    })();
  </script>
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link
    href="https://fonts.googleapis.com/css2?family=Lora:ital,wght@0,400;0,500;0,600;0,700;1,400&family=Noto+Sans+JP:wght@300;400;500;600;700&family=Noto+Serif+JP:wght@400;500;600;700&family=Sora:wght@300;400;500;600;700&family=Google+Sans+Code:ital,wght@0,400;0,500;0,700;1,400&display=swap"
    rel="stylesheet"
  />
  <style is:global>
    /* ── Reset & Base ─────────────────────────────────────────────── */
    *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }

    :root {
      --bg: #ffffff;
      --fg: #343434;
      --fg-muted: #777777;
      --border: #e8e8e8;
      --link: rgb(49, 113, 222);
      --sidebar-width: 375px;
      --header-height: 64px;
      --font-body: 'Sora', 'Noto Sans JP', sans-serif;
      --font-code: 'Google Sans Code', 'Fira Mono', monospace;
    }
    html[data-font="serif"] {
      --font-body: 'Lora', 'Noto Serif JP', serif;
    }

    html, body {
      background: var(--bg);
      color: var(--fg);
      font-family: var(--font-body);
      font-size: 18px;
      line-height: 1.7;
      min-height: 100vh;
    }

    /* ── Layout Shell ─────────────────────────────────────────────── */
    .shell {
      display: flex;
      min-height: 100vh;
    }

    /* ── Top Bar ──────────────────────────────────────────────────── */
    .topbar {
      position: fixed;
      top: 0; left: 0; right: 0;
      height: var(--header-height);
      background: transparent;
      display: flex;
      align-items: center;
      justify-content: space-between;
      padding: 0 1rem;
      z-index: 100;
      pointer-events: none;
    }

    .topbar-controls {
      display: flex;
      align-items: center;
      background: rgba(255, 255, 255, 0.76);
      border-radius: 8px;
      backdrop-filter: blur(6px);
      -webkit-backdrop-filter: blur(6px);
      pointer-events: all;
    }
    .topbar-controls-left { padding: 0.22rem; }
    .topbar-controls-right { padding: 0.22rem 0.55rem; }

    .topbar-toggle {
      display: flex;
      align-items: center;
      justify-content: center;
      width: 30px;
      height: 30px;
      background: none;
      border: none;
      cursor: pointer;
      color: var(--fg);
      border-radius: 5px;
      transition: background 0.15s;
      flex-shrink: 0;
    }
    .topbar-toggle:hover { background: rgba(0,0,0,0.06); }

    .topbar-font-switcher {
      display: flex;
      align-items: center;
      gap: 0.25rem;
    }
    .font-opt {
      background: none;
      border: none;
      cursor: pointer;
      padding: 0.2rem 0.1rem;
      font-size: 0.75rem;
      color: var(--fg-muted);
      letter-spacing: 0.01em;
      transition: color 0.15s;
    }
    .font-opt:hover { color: var(--fg); }
    .font-opt.active { color: var(--fg); font-weight: 600; }
    .font-sep { color: #ccc; font-size: 0.75rem; user-select: none; }

    /* ── Content breadcrumb ───────────────────────────────────────── */
    .content-breadcrumb {
      display: flex;
      flex-wrap: wrap;
      align-items: center;
      gap: 0.2rem 0.3rem;
      font-size: 0.75rem;
      color: var(--fg-muted);
      margin-bottom: 2.1rem;
    }
    .content-breadcrumb a {
      color: var(--fg-muted);
      text-decoration: none;
    }
    .content-breadcrumb a:hover { color: var(--fg); }
    .content-breadcrumb .cb-sep { color: #ccc; }

    /* ── Sidebar ──────────────────────────────────────────────────── */
    .sidebar-backdrop {
      display: none;
      position: fixed;
      inset: 0;
      background: rgba(0,0,0,0.08);
      z-index: 98;
    }

    .sidebar {
      position: fixed;
      top: 0;
      left: 0;
      bottom: 0;
      width: var(--sidebar-width);
      background: var(--bg);
      overflow-y: auto;
      z-index: 101;
      transform: translateX(calc(-1 * var(--sidebar-width)));
      transition: transform 0.22s ease;
      padding: 1rem 0 2rem;
    }

    .shell.sidebar-open .sidebar {
      transform: translateX(0);
      box-shadow: 4px 0 24px rgba(0,0,0,0.07);
    }

    .shell.no-transition .sidebar,
    .shell.no-transition .main-wrap {
      transition: none !important;
    }

    .shell.sidebar-open .sidebar-backdrop {
      display: block;
    }

    /* ── Main Content ─────────────────────────────────────────────── */
    .main-wrap {
      flex: 1;
      margin-top: var(--header-height);
      margin-left: 0;
      transition: margin-left 0.22s ease;
      min-width: 0;
    }

    .shell.sidebar-open .main-wrap {
      margin-left: var(--sidebar-width);
    }

    .main-inner {
      max-width: 860px;
      margin: 0 auto;
      padding: 2.5rem 2.5rem 5rem;
    }

    /* ── Article Typography (is:global so it reaches markdown content) */
    .prose h1.page-title {
      font-size: 3rem;
      font-weight: 300;
      letter-spacing: -0.03em;
      line-height: 1.15;
      margin-bottom: 3rem;
    }
    .prose h1 {
      font-size: 1.55rem;
      font-weight: 600;
      letter-spacing: -0.02em;
      line-height: 1.25;
      margin-top: 2.75rem;
      margin-bottom: 0.6rem;
    }
    .prose h2 {
      font-size: 1.25rem;
      font-weight: 600;
      letter-spacing: -0.02em;
      margin-top: 2.25rem;
      margin-bottom: 0.6rem;
    }
    .prose h3 {
      font-size: 1.05rem;
      font-weight: 600;
      margin-top: 1.75rem;
      margin-bottom: 0.4rem;
    }
    /* Bilingual heading pairs: collapse gap between English + Japanese, generous space after */
    .prose h1 + h1,
    .prose h2 + h2,
    .prose h3 + h3 {
      margin-top: 0.1em;
      margin-bottom: 1.6rem;
    }
    .prose p {
      margin-bottom: 2.1rem;
    }
    .prose a {
      color: var(--link);
      text-decoration: none;
    }
    .prose a:hover { opacity: 0.75; }
    .prose ul, .prose ol {
      padding-left: 1.5rem;
      margin-bottom: 1rem;
    }
    .prose li { margin-bottom: 0.25rem; }
    .prose blockquote {
      border-left: 2px solid var(--border);
      padding-left: 1rem;
      color: var(--fg-muted);
      margin: 1rem 0;
    }
    .prose code {
      font-family: var(--font-code);
      font-size: 0.87em;
      background: #f5f5f5;
      padding: 0.15em 0.35em;
      border-radius: 3px;
    }
    .prose pre {
      font-family: var(--font-code);
      font-size: 0.87em;
      background: #f5f5f5;
      border-radius: 5px;
      padding: 1.25rem;
      overflow-x: auto;
      margin: 1.25rem 0;
    }
    .prose pre code {
      background: none;
      padding: 0;
    }
    .prose img {
      max-width: 100%;
      width: auto !important;
      height: auto !important;
      display: block;
      border-radius: 4px;
      margin: 3rem 0;
    }
    .prose .video-wrap {
      position: relative;
      width: 100%;
      padding-bottom: 56.25%; /* 16:9 */
      margin: 3rem 0;
    }
    .prose .video-wrap iframe {
      position: absolute;
      inset: 0;
      width: 100%;
      height: 100%;
      border: none;
      border-radius: 4px;
    }
    .prose .codepen-wrap {
      margin: 3rem 0;
      border-radius: 4px;
      overflow: hidden;
    }
    .prose .codepen-wrap iframe {
      display: block;
      border-radius: 4px;
    }
    .prose .instagram-wrap {
      margin: 3rem 0;
    }
    .prose .bookmark-card {
      margin: 2rem 0;
      border: 1px solid var(--border);
      border-radius: 6px;
      overflow: hidden;
      transition: border-color 0.15s;
    }
    .prose .bookmark-card:hover { border-color: #bbb; }
    .prose .bookmark-link {
      display: flex;
      align-items: stretch;
      text-decoration: none;
      color: inherit;
      min-height: 6em;
      max-height: 9em;
      overflow: hidden;
    }
    .prose .bookmark-info {
      flex: 1 1 0;
      min-width: 0;
      padding: 0.85rem 1rem;
      display: flex;
      flex-direction: column;
      justify-content: space-between;
      gap: 0.3rem;
    }
    .prose .bookmark-title {
      font-size: 0.88em;
      font-weight: 500;
      color: var(--fg);
      white-space: nowrap;
      overflow: hidden;
      text-overflow: ellipsis;
    }
    .prose .bookmark-description {
      font-size: 0.78em;
      color: var(--fg-muted);
      overflow: hidden;
      display: -webkit-box;
      -webkit-line-clamp: 2;
      -webkit-box-orient: vertical;
      flex: 1;
      line-height: 1.5;
    }
    .prose .bookmark-url {
      font-size: 0.72em;
      color: var(--fg-muted);
      display: flex;
      align-items: center;
      gap: 5px;
      white-space: nowrap;
      overflow: hidden;
      text-overflow: ellipsis;
    }
    .prose .bookmark-url span {
      overflow: hidden;
      text-overflow: ellipsis;
    }
    .prose .bookmark-favicon {
      width: 14px !important;
      height: 14px !important;
      flex-shrink: 0;
      object-fit: contain;
      border-radius: 0;
      margin: 0;
      display: inline-block;
    }
    .prose .bookmark-image {
      width: 180px !important;
      height: 100% !important;
      flex-shrink: 0;
      object-fit: cover;
      display: block;
      border-radius: 0;
      margin: 0;
      align-self: stretch;
    }
    @media (max-width: 540px) {
      .prose .bookmark-image { display: none; }
    }
    .prose hr {
      border: none;
      border-top: 1px solid var(--border);
      margin: 2rem 0;
    }
    .prose table {
      width: 100%;
      border-collapse: collapse;
      margin: 1.25rem 0;
      font-size: 0.9em;
    }
    .prose th, .prose td {
      border: 1px solid var(--border);
      padding: 0.5rem 0.75rem;
      text-align: left;
    }
    .prose th { font-weight: 600; background: #fafafa; }
    .prose table.matrix-table {
      width: auto;
      font-family: var(--font-code);
      font-size: 0.85em;
    }
    .prose table.matrix-table td {
      text-align: center;
      padding: 0.3rem 0.75rem;
      min-width: 3rem;
    }
    .prose details {
      border: 1px solid var(--border);
      border-radius: 4px;
      padding: 0.5rem 0.75rem;
      margin: 0.75rem 0;
    }
    .prose summary { cursor: pointer; font-weight: 500; }

    /* ── Site Footer ─────────────────────────────────────────────── */
    .site-footer {
      display: flex;
      justify-content: space-between;
      align-items: center;
      flex-wrap: wrap;
      gap: 0.5rem 1.5rem;
      margin-top: 4rem;
      padding-top: 1.25rem;
      border-top: 1px solid var(--border);
      font-size: 0.8rem;
      color: var(--fg-muted);
    }
    .site-footer a {
      color: var(--fg-muted);
      text-decoration: none;
    }
    .site-footer a:hover { color: var(--fg); }
    .site-footer-left, .site-footer-right {
      display: flex;
      align-items: center;
      gap: 1rem;
      flex-wrap: wrap;
    }

    /* ── Mobile ───────────────────────────────────────────────────── */
    @media (max-width: 768px) {
      .shell.sidebar-open .main-wrap {
        margin-left: 0;
      }
      .main-inner {
        padding: 1.5rem 1.25rem 3rem;
      }
      .prose h1 { font-size: 1.5rem; }
    }
  </style>
</head>
<body>
  <header class="topbar">
    <div class="topbar-controls topbar-controls-left">
      <button class="topbar-toggle" id="sidebar-toggle" aria-label="Toggle sidebar">
        <svg width="18" height="14" viewBox="0 0 18 14" fill="none" stroke="currentColor" stroke-width="1.75" stroke-linecap="round">
          <line x1="0" y1="1" x2="18" y2="1"/>
          <line x1="0" y1="7" x2="18" y2="7"/>
          <line x1="0" y1="13" x2="18" y2="13"/>
        </svg>
      </button>
    </div>
    <div class="topbar-controls topbar-controls-right">
      <div class="topbar-font-switcher">
        <button class="font-opt" id="font-btn-serif" style="font-family:'Lora','Noto Serif JP',serif">Serif</button>
        <span class="font-sep">|</span>
        <button class="font-opt" id="font-btn-sans" style="font-family:'Sora','Noto Sans JP',sans-serif">Sans</button>
      </div>
    </div>
  </header>

  <div class="shell" id="app-shell">
    <div class="sidebar-backdrop" id="sidebar-backdrop"></div>

    <nav class="sidebar" aria-label="Site navigation">
      <Sidebar tree={tree} currentSlug={slug} />
    </nav>

    <main class="main-wrap">
      <div class="main-inner">
        <article class="prose">
          {breadcrumbs.length > 2 && (
            <nav class="content-breadcrumb" aria-label="Breadcrumb">
              {breadcrumbs.slice(0, -1).map((crumb, i) => (
                <span style="display:contents">
                  {i > 0 && <span class="cb-sep">/</span>}
                  <a href={crumb.href}>{crumb.label}</a>
                </span>
              ))}
            </nav>
          )}
          <slot />
        </article>
        <footer class="site-footer">
          <div class="site-footer-left">
            <a href={base || '/'}>Index</a>
            <a href={`${base}/faq`}>FAQs</a>
          </div>
          <div class="site-footer-right">
            <a href="https://www.kynd.info/" target="_blank" rel="noopener">kynd.info</a>
            <a href="https://www.instagram.com/kyndinfo/" target="_blank" rel="noopener">Instagram</a>
            <a href="https://vimeo.com/kynd" target="_blank" rel="noopener">Vimeo</a>
            <a href="https://bsky.app/profile/kyndinfo.bsky.social" target="_blank" rel="noopener">Bluesky</a>
            <a href="https://www.threads.net/@kyndinfo" target="_blank" rel="noopener">Threads</a>
            <a href="https://twitter.com/kyndinfo" target="_blank" rel="noopener">Twitter</a>
          </div>
        </footer>
      </div>
    </main>
  </div>

  <script>
    const STORAGE_KEY = 'sidebar-open';
    const shell = document.getElementById('app-shell')!;
    const toggleBtn = document.getElementById('sidebar-toggle')!;
    const backdrop = document.getElementById('sidebar-backdrop')!;
    const isMobile = () => window.innerWidth <= 768;

    function applyState(open: boolean) {
      shell.classList.toggle('sidebar-open', open);
      localStorage.setItem(STORAGE_KEY, String(open));
    }

    const stored = localStorage.getItem(STORAGE_KEY);
    shell.classList.add('no-transition');
    applyState(stored === 'true');
    requestAnimationFrame(() => shell.classList.remove('no-transition'));

    toggleBtn.addEventListener('click', () => {
      applyState(!shell.classList.contains('sidebar-open'));
    });

    backdrop.addEventListener('click', () => applyState(false));

    document.addEventListener('click', (e) => {
      if (!shell.classList.contains('sidebar-open')) return;
      const sidebar = document.querySelector('.sidebar')!;
      if (!sidebar.contains(e.target as Node) && !toggleBtn.contains(e.target as Node)) {
        applyState(false);
      }
    });

    // Font switcher
    const FONT_KEY = 'font-mode';
    const btnSerif = document.getElementById('font-btn-serif')!;
    const btnSans = document.getElementById('font-btn-sans')!;
    function applyFont(mode: string) {
      document.documentElement.setAttribute('data-font', mode);
      localStorage.setItem(FONT_KEY, mode);
      btnSerif.classList.toggle('active', mode === 'serif');
      btnSans.classList.toggle('active', mode === 'sans');
    }
    applyFont(localStorage.getItem(FONT_KEY) || 'serif');
    btnSerif.addEventListener('click', () => applyFont('serif'));
    btnSans.addEventListener('click', () => applyFont('sans'));

    // Click image to open in new tab
    document.querySelectorAll<HTMLImageElement>('.prose img').forEach((img) => {
      img.style.cursor = 'zoom-in';
      img.addEventListener('click', (e) => {
        e.preventDefault();
        e.stopPropagation();
        window.open(img.src, '_blank', 'noopener');
      });
    });
  </script>
</body>
</html>
